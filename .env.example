# Database (Supabase / PostgreSQL)
# Supabase: use Transaction Pooler URL (port 6543, ?pgbouncer=true) for DATABASE_URL
# and the Direct connection URL (port 5432) for DIRECT_URL (needed for prisma migrate deploy)
DATABASE_URL="postgresql://postgres.YOURREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:PASSWORD@db.YOURREF.supabase.co:5432/postgres"

# NextAuth v5 — REQUIRED for auth to work
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="your-random-secret-here"

# Your production URL (no trailing slash)
NEXTAUTH_URL="https://your-project.vercel.app"
